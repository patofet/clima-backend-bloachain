{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/project",
      "program": "${workspaceFolder}/project/python-scripts/main.py",
      "python": "${workspaceFolder}/project/python-scripts/.venv/bin/python",
      "console": "integratedTerminal"
    },
    {
      "name": "Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/project",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Deploy local", //deploy:local
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/project",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "deploy:local"],
      "console": "integratedTerminal"
    },
    {
      "name": "Autocertifier",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/project/autocertifier.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Plot Blockchain Logs",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/plot_blockchain_logs.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [],
      "justMyCode": true
    },
    {
      "name": "Plot Blockchain Logs (Debug)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/plot_blockchain_logs.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [],
      "justMyCode": false,
      "stopOnEntry": false
    }
  ]
}
